  "rsa": "South Africa",\u005cn    "bafana bafana": "South Africa",\u005cn\u005cn    # ---- South Korea ----\u005cn    "south korea": "South Korea",\u005cn    "korea republic": "South Korea",\u005cn    "republic of korea": "South Korea",\u005cn    "korea, republic of": "South Korea",\u005cn    "korea (south)": "South Korea",\u005cn    "kor": "South Korea",\u005cn\u005cn    # ---- Spain ----\u005cn    "spain": "Spain",\u005cn    "espana": "Spain",\u005cn    "esp": "Spain",\u005cn\u005cn    # ---- Sweden ----\u005cn    "sweden": "Sweden",\u005cn    "sverige": "Sweden",\u005cn    "swe": "Sweden",\u005cn\u005cn    # ---- Switzerland ----\u005cn    "switzerland": "Switzerland",\u005cn    "schweiz": "Switzerland",\u005cn    "suisse": "Switzerland",\u005cn    "svizzera": "Switzerland",\u005cn    "sui": "Switzerland",\u005cn\u005cn    # ---- Syria ----\u005cn    "syria": "Syria",\u005cn    "syr": "Syria",\u005cn\u005cn    # ---- Tanzania ----\u005cn    "tanzania": "Tanzania",\u005cn\u005cn    # ---- Thailand ----\u005cn    "thailand": "Thailand",\u005cn    "tha": "Thailand",\u005cn\u005cn    # ---- Togo ----\u005cn    "togo": "Togo",\u005cn    "tog": "Togo",\u005cn\u005cn    # ---- Trinidad and Tobago ----\u005cn    "trinidad and tobago": "Trinidad and Tobago",\u005cn    "trinidad & tobago": "Trinidad and Tobago",\u005cn    "tnt": "Trinidad and Tobago",\u005cn    "tri": "Trinidad and Tobago",\u005cn\u005cn    # ---- Tunisia ----\u005cn    "tunisia": "Tunisia",\u005cn    "tun": "Tunisia",\u005cn\u005cn    # ---- Turkey ----\u005cn    "turkey": "Turkey",\u005cn    "turkiye": "Turkey",\u005cn    "tur": "Turkey",\u005cn\u005cn    # ---- Uganda ----\u005cn    "uganda": "Uganda",\u005cn\u005cn    # ---- Ukraine ----\u005cn    "ukraine": "Ukraine",\u005cn    "ukr": "Ukraine",\u005cn\u005cn    # ---- United Arab Emirates ----\u005cn    "united arab emirates": "United Arab Emirates",\u005cn    "uae": "United Arab Emirates",\u005cn\u005cn    # ---- United States ----\u005cn    "united states": "United States",\u005cn    "usa": "United States",\u005cn    "us": "United States",\u005cn    "united states of america": "United States",\u005cn    "u.s.a.": "United States",\u005cn    "u.s.": "United States",\u005cn    "usmnt": "United States",\u005cn\u005cn    # ---- Uruguay ----\u005cn    "uruguay": "Uruguay",\u005cn    "uru": "Uruguay",\u005cn\u005cn    # ---- Uzbekistan ----\u005cn    "uzbekistan": "Uzbekistan",\u005cn    "uzb": "Uzbekistan",\u005cn\u005cn    # ---- Venezuela ----\u005cn    "venezuela": "Venezuela",\u005cn    "ven": "Venezuela",\u005cn\u005cn    # ---- Vietnam ----\u005cn    "vietnam": "Vietnam",\u005cn    "viet nam": "Vietnam",\u005cn    "vnm": "Vietnam",\u005cn\u005cn    # ---- Wales ----\u005cn    "wales": "Wales",\u005cn    "cymru": "Wales",\u005cn    "wal": "Wales",\u005cn\u005cn    # ---- Zambia ----\u005cn    "zambia": "Zambia",\u005cn    "zam": "Zambia",\u005cn\u005cn    # ---- Zimbabwe ----\u005cn    "zimbabwe": "Zimbabwe",\u005cn    "zim": "Zimbabwe",\u005cn}\u005cn\u005cn\u005cndef _strip_accents(text: str) -> str:\u005cn    """Remove diacritics/accents from a string using NFKD normalisation."""\u005cn    nfkd = unicodedata.normalize("NFKD", text)\u005cn    return "".join(c for c in nfkd if not unicodedata.combining(c))\u005cn\u005cn\u005cndef resolve_country(name: str) -> str:\u005cn    """Return the canonical common-English country name for *name*.\u005cn\u005cn    Steps:\u005cn    1. Strip leading/trailing whitespace.\u005cn    2. NFKD-normalise to remove accents (so ``"Côte d\u005c'Ivoire"`` \u2192 ``"cote d\u005c'ivoire"``).\u005cn    3. Lower-case.\u005cn    4. Look up in ``COUNTRY_ALIASES``; return canonical if found.\u005cn    5. Otherwise return the original string title-cased (preserving unknown names).\u005cn\u005cn    Parameters\u005cn    ----------\u005cn    name:\u005cn        Raw country/team name from any data source.\u005cn\u005cn    Returns\u005cn    -------\u005cn    str\u005cn        Canonical common-English name, or title-cased original if unknown.\u005cn    """\u005cn    if not isinstance(name, str):\u005cn        return str(name).strip()\u005cn    name = name.strip()\u005cn    if not name:\u005cn        return name\u005cn    key = _strip_accents(name).lower()\u005cn    if key in COUNTRY_ALIASES:\u005cn        return COUNTRY_ALIASES[key]\u005cn    # Try after collapsing internal whitespace\u005cn    key_collapsed = " ".join(key.split())\u005cn    if key_collapsed in COUNTRY_ALIASES:\u005cn        return COUNTRY_ALIASES[key_collapsed]\u005cn    # Unknown \u2014 return title-cased original (preserves club names, etc.)\u005cn    return " ".join(name.split()).title()\u005cn\u005cn\u005cnimport os\u005cnos.environ[\u005c'PYDEVD_DISABLE_FILE_VALIDATION\u005c'] = \u005c'1\u005c'\u005cnimport numpy as np\u005cnimport pandas as pd\u005cnimport scipy.stats as stats\u005cn\u005cnnan = float(\u005c'nan\u005c')\u005cnNaN = float(\u005c'nan\u005c')\u005cn\u005cnclass PurePythonPipeline:\u005cn    def __init__(self, params):\u005cn        self.params = params\u005cn\u005cn    def predict(self, X):\u005cn        if self.params.get("type") == "dummy_regressor":\u005cn            constant = self.params["constant"]\u005cn            if isinstance(constant, list):\u005cn                if isinstance(constant[0], list):\u005cn                    val = float(constant[0][0])\u005cn                else:\u005cn                    val = float(constant[0])\u005cn            else:\u005cn                val = float(constant)\u005cn            return np.full((len(X),), val)\u005cn            \u005cn        elif self.params.get("type") == "dummy_classifier":\u005cn            constant = self.params["constant"]\u005cn            val = constant[0] if isinstance(constant, list) else constant\u005cn            return np.full((len(X),), val)\u005cn            \u005cn        elif self.params.get("type") == "poisson":\u005cn            mean = np.array(self.params["scaler_mean"])\u005cn            scale = np.array(self.params["scaler_scale"])\u005cn            coef = np.array(self.params["model_coef"])\u005cn            intercept = float(self.params["model_intercept"])\u005cn            \u005cn            if hasattr(X, "values"):\u005cn                X_arr = X.values\u005cn            else:\u005cn                X_arr = np.array(X)\u005cn                \u005cn            X_scaled = (X_arr - mean) / scale\u005cn            return np.exp(np.dot(X_scaled, coef) + intercept)\u005cn            \u005cn        elif self.params.get("type") == "logistic":\u005cn            mean = np.array(self.params["scaler_mean"])\u005cn            scale = np.array(self.params["scaler_scale"])\u005cn            coef = np.array(self.params["model_coef"])\u005cn            intercept = np.array(self.params["model_intercept"])\u005cn            classes = np.array(self.params["classes"])\u005cn            \u005cn            if hasattr(X, "values"):\u005cn                X_arr = X.values\u005cn            else:\u005cn                X_arr = np.array(X)\u005cn                \u005cn            X_scaled = (X_arr - mean) / scale\u005cn            z = np.dot(X_scaled, coef.T) + intercept\u005cn            \u005cn            if len(classes) == 2:\u005cn                p = 1.0 / (1.0 + np.exp(-z))\u005cn                p_flat = p.flatten()\u005cn                preds = np.where(p_flat >= 0.5, classes[1], classes[0])\u005cn                return preds\u005cn            else:\u005cn                exp_z = np.exp(z - np.max(z, axis=1, keepdims=True))\u005cn                p = exp_z / np.sum(exp_z, axis=1, keepdims=True)\u005cn                idx = np.argmax(p, axis=1)\u005cn                return classes[idx]\u005cn        else:\u005cn            raise ValueError(f"Unknown type: {self.params.get(\u005c'type\u005c')}")\u005cn\u005cn    def predict_proba(self, X):\u005cn        if self.params.get("type") == "dummy_classifier":\u005cn            classes = np.array(self.params["classes"])\u005cn            constant = self.params["constant"]\u005cn            val = constant[0] if isinstance(constant, list) else constant\u005cn            idx = np.where(classes == val)[0][0]\u005cn            proba = np.zeros((len(X), len(classes)))\u005cn            proba[:, idx] = 1.0\u005cn            return proba\u005cn            \u005cn        elif self.params.get("type") == "logistic":\u005cn            mean = np.array(self.params["scaler_mean"])\u005cn            scale = np.array(self.params["scaler_scale"])\u005cn            coef = np.array(self.params["model_coef"])\u005cn            intercept = np.array(self.params["model_intercept"])\u005cn            classes = np.array(self.params["classes"])\u005cn            \u005cn            if hasattr(X, "values"):\u005cn                X_arr = X.values\u005cn            else:\u005cn                X_arr = np.array(X)\u005cn                \u005cn            X_scaled = (X_arr - mean) / scale\u005cn            z = np.dot(X_scaled, coef.T) + intercept\u005cn            \u005cn            if len(classes) == 2:\u005cn                p = 1.0 / (1.0 + np.exp(-z))\u005cn                p_flat = p.flatten()\u005cn                return np.vstack([1.0 - p_flat, p_flat]).T\u005cn            else:\u005cn                exp_z = np.exp(z - np.max(z, axis=1, keepdims=True))\u005cn                return exp_z / np.sum(exp_z, axis=1, keepdims=True)\u005cn        else:\u005cn            raise ValueError(f"predict_proba not supported for: {self.params.get(\u005c'type\u005c')}")\u005cn\u005cn    @property\u005cn    def classes_(self):\u005cn        return np.array(self.params.get("classes", []))\u005cn\u005cn\u005cnclass PurePythonCalibrationLayer:\u005cn    def __init__(self, params):\u005cn        self.params = params\u005cn\u005cn    def transform(self, raw_probs):\u005cn        arr = np.array(raw_probs, dtype=float)\u005cn        result = np.zeros_like(arr)\u005cn        for i, cal in enumerate(self.params["calibrators"]):\u005cn            x = np.array(cal["x"])\u005cn            y = np.array(cal["y"])\u005cn            result[:, i] = np.interp(arr[:, i], x, y)\u005cn        row_sums = result.sum(axis=1, keepdims=True)\u005cn        return result / np.maximum(row_sums, 1e-9)\u005cn\u005cn\u005cnclass PredictorWrapper:\u005cn    def __init__(self, artifact):\u005cn        self.artifact = artifact\u005cn        self.team_profiles = artifact.get("team_profiles", {})\u005cn        self.player_profiles = artifact.get("player_profiles", [])\u005cn        self.home_goals_model = artifact.get("home_goals_model")\u005cn        self.away_goals_model = artifact.get("away_goals_model")\u005cn        self.calibration_layer = artifact.get("calibration_layer")\u005cn\u005cn    def __getitem__(self, key):\u005cn        return self.artifact[key]\u005cn\u005cn    def __setitem__(self, key, value):\u005cn        self.artifact[key] = value\u005cn\u005cn    def get(self, key, default=None):\u005cn        return self.artifact.get(key, default)\u005cn\u005cn    def __contains__(self, key):\u005cn        return key in self.artifact\u005cn\u005cn    def keys(self):\u005cn        return self.artifact.keys()\u005cn\u005cn    def values(self):\u005cn        return self.artifact.values()\u005cn\u005cn    def items(self):\u005cn        return self.artifact.items()\u005cn\u005cn    def predict(self, home_team, away_team=None) -> dict:\u005cn        if isinstance(home_team, dict):\u005cn            away_team = home_team.get("away_team")\u005cn            home_team = home_team.get("home_team")\u005cn        elif hasattr(home_team, "get"):\u005cn            away_team = home_team.get("away_team")\u005cn            home_team = home_team.get("home_team")\u005cn\u005cn        def normalize_name(team):\u005cn            if not isinstance(team, str):\u005cn                if pd.isna(team):\u005cn                    return ""\u005cn                team = str(team)\u005cn            return resolve_country(" ".join(team.strip().split()))\u005cn\u005cn        h_team = normalize_name(home_team)\u005cn        a_team = normalize_name(away_team)\u005cn\u005cn        if h_team not in self.team_profiles or a_team not in self.team_profiles:\u005cn            return {\u005cn                "output": {\u005cn                    "match_prediction": {\u005cn                        "win_probabilities": {\u005cn                            "home_team": {\u005cn                                "team": h_team,\u005cn                                "probability": "Data Unavailable",\u005cn                            },\u005cn                            "draw": {"probability": "Data Unavailable"},\u005cn                            "away_team": {\u005cn                                "team": a_team,\u005cn                                "probability": "Data Unavailable",\u005cn                            },\u005cn                        }\u005cn                    },\u005cn                    "score_prediction": {\u005cn                        "predicted_scoreline": {\u005cn                            "home_team": h_team,\u005cn                            "home_goals": "Data Unavailable",\u005cn                            "away_team": a_team,\u005cn                            "away_goals": "Data Unavailable",\u005cn                        },\u005cn                        "total_goals": "Data Unavailable",\u005cn                    },\u005cn                    "goal_insights": {\u005cn                        "first_team_to_score": {\u005cn                            "team": "Data Unavailable",\u005cn                            "probability": "Data Unavailable",\u005cn                        },\u005cn                        "both_teams_to_score": {\u005cn                            "prediction": "Data Unavailable",\u005cn                            "probability": "Data Unavailable",\u005cn                        },\u005cn                    },\u005cn                    "player_prediction": {\u005cn                        "home_team": {\u005cn                            "team": h_team,\u005cn                            "goal": "Data Unavailable",\u005cn                            "clean_sheet_prediction": {\u005cn                                "goalkeeper": "Data Unavailable",\u005cn                                "prediction": "Data Unavailable",\u005cn                                "probability": "Data Unavailable",\u005cn                            },\u005cn                        },\u005cn                        "away_team": {\u005cn                            "team": a_team,\u005cn                            "goal": "Data Unavailable",\u005cn                            "clean_sheet_prediction": {\u005cn                                "goalkeeper": "Data Unavailable",\u005cn                                "prediction": "Data Unavailable",\u005cn                                "probability": "Data Unavailable",\u005cn                            },\u005cn                        },\u005cn                    },\u005cn                }\u005cn            }\u005cn\u005cn        def get_val(profile, attr, default=0.0):\u005cn            if isinstance(profile, dict):\u005cn                return profile.get(attr, default)\u005cn            return getattr(profile, attr, default)\u005cn\u005cn        if h_team not in self.team_profiles:\u005cn            if self.team_profiles:\u005cn                avg_elo = sum(get_val(p, "elo") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn                avg_rank = sum(get_val(p, "elo_rank") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn            else:\u005cn                avg_elo, avg_rank = 1500.0, 50.0\u005cn            home = {"team": h_team, "elo": avg_elo, "elo_rank": avg_rank, "gk_save_ratio": 0.70, "gk_prevented_per_90": 0.0}\u005cn        else:\u005cn            home = self.team_profiles[h_team]\u005cn\u005cn        if a_team not in self.team_profiles:\u005cn            if self.team_profiles:\u005cn                avg_elo = sum(get_val(p, "elo") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn                avg_rank = sum(get_val(p, "elo_rank") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn            else:\u005cn                avg_elo, avg_rank = 1400.0, 50.0\u005cn            away = {"team": a_team, "elo": avg_elo, "elo_rank": avg_rank, "gk_save_ratio": 0.70, "gk_prevented_per_90": 0.0}\u005cn        else:\u005cn            away = self.team_profiles[a_team]\u005cn\u005cn        _STAT_DEFAULTS = {\u005cn            "attack_rating": 45.0,\u005cn            "defense_rating": 45.0,\u005cn            "goals_avg": 1.25,\u005cn            "conceded_avg": 1.25,\u005cn            "win_rate": 0.35,\u005cn            "clean_sheet_rate": 0.25,\u005cn            "xg_avg": 1.20,\u005cn            "form_pts": 6.0,\u005cn            "first_goal_rate": 0.40,\u005cn        }\u005cn\u005cn        def _get_feature_vector(home_name, away_name):\u005cn            def _fallback_profile(name):\u005cn                if self.team_profiles:\u005cn                    avg_elo = sum(get_val(p, "elo") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn                    avg_rank = sum(get_val(p, "elo_rank") for p in self.team_profiles.values()) / len(self.team_profiles)\u005cn                else:\u005cn                    avg_elo, avg_rank = 1500.0, 50.0\u005cn                p = {"team": name, "elo": avg_elo, "elo_rank": avg_rank}\u005cn                p.update(_STAT_DEFAULTS)\u005cn                p["gk_save_ratio"] = 0.70\u005cn                p["gk_prevented_per_90"] = 0.0\u005cn                return p\u005cn\u005cn            home = self.team_profiles.get(home_name)\u005cn            if not home:\u005cn                home = _fallback_profile(home_name)\u005cn            away = self.team_profiles.get(away_name)\u005cn            if not away:\u005cn                away = _fallback_profile(away_name)\u005cn\u005cn            row = {\u005cn                # Core ELO\u005cn                "home_elo":      get_val(home, "elo"),\u005cn                "away_elo":      get_val(away, "elo"),\u005cn                "home_elo_rank": get_val(home, "elo_rank"),\u005cn                "away_elo_rank": get_val(away, "elo_rank"),\u005cn                # GK\u005cn                "home_gk_save_ratio":       get_val(home, "gk_save_ratio",       0.70),\u005cn                "away_gk_save_ratio":       get_val(away, "gk_save_ratio",       0.70),\u005cn                "home_gk_prevented_per_90": get_val(home, "gk_prevented_per_90", 0.0),\u005cn                "away_gk_prevented_per_90": get_val(away, "gk_prevented_per_90", 0.0),\u005cn                # Extended\u005cn                "home_attack_rating":  get_val(home, "attack_rating",  _STAT_DEFAULTS["attack_rating"]),\u005cn                "away_attack_rating":  get_val(away, "attack_rating",  _STAT_DEFAULTS["attack_rating"]),\u005cn                "home_defense_rating": get_val(home, "defense_rating", _STAT_DEFAULTS["defense_rating"]),\u005cn                "away_defense_rating": get_val(away, "defense_rating", _STAT_DEFAULTS["defense_rating"]),\u005cn                "home_goals_avg":      get_val(home, "goals_avg",      _STAT_DEFAULTS["goals_avg"]),\u005cn                "away_goals_avg":      get_val(away, "goals_avg",      _STAT_DEFAULTS["goals_avg"]),\u005cn                "home_conceded_avg":   get_val(home, "conceded_avg",   _STAT_DEFAULTS["conceded_avg"]),\u005cn                "away_conceded_avg":   get_val(away, "conceded_avg",   _STAT_DEFAULTS["conceded_avg"]),\u005cn                "home_win_rate":         get_val(home, "win_rate",         _STAT_DEFAULTS["win_rate"]),\u005cn                "away_win_rate":         get_val(away, "win_rate",         _STAT_DEFAULTS["win_rate"]),\u005cn                "home_clean_sheet_rate": get_val(home, "clean_sheet_rate", _STAT_DEFAULTS["clean_sheet_rate"]),\u005cn                "away_clean_sheet_rate": get_val(away, "clean_sheet_rate", _STAT_DEFAULTS["clean_sheet_rate"]),\u005cn                "home_xg_avg":    get_val(home, "xg_avg",    _STAT_DEFAULTS["xg_avg"]),\u005cn                "away_xg_avg":    get_val(away, "xg_avg",    _STAT_DEFAULTS["xg_avg"]),\u005cn                "home_form_pts":  get_val(home, "form_pts",  _STAT_DEFAULTS["form_pts"]),\u005cn                "away_form_pts":  get_val(away, "form_pts",  _STAT_DEFAULTS["form_pts"]),\u005cn                "home_first_goal_rate": get_val(home, "first_goal_rate", _STAT_DEFAULTS["first_goal_rate"]),\u005cn                "away_first_goal_rate": get_val(away, "first_goal_rate", _STAT_DEFAULTS["first_goal_rate"]),\u005cn            }\u005cn\u005cn            frame = pd.DataFrame([row])\u005cn\u005cn            # Compute differentials\u005cn            frame["elo_diff"]          = frame["home_elo"]           - frame["away_elo"]\u005cn            frame["rank_diff"]         = frame["away_elo_rank"]      - frame["home_elo_rank"]\u005cn            frame["attack_diff"]       = frame["home_attack_rating"] - frame["away_attack_rating"]\u005cn            frame["defense_diff"]      = frame["home_defense_rating"]- frame["away_defense_rating"]\u005cn            frame["goals_avg_diff"]    = frame["home_goals_avg"]     - frame["away_goals_avg"]\u005cn            frame["conceded_avg_diff"] = frame["home_conceded_avg"]  - frame["away_conceded_avg"]\u005cn            frame["win_rate_diff"]     = frame["home_win_rate"]      - frame["away_win_rate"]\u005cn            frame["xg_avg_diff"]       = frame["home_xg_avg"]        - frame["away_xg_avg"]\u005cn            frame["form_diff"]         = frame["home_form_pts"]      - frame["away_form_pts"]\u005cn\u005cn            return frame[self.artifact["feature_columns"]]\u005cn\u005cn        features = _get_feature_vector(h_team, a_team)\u005cn        features_swapped = _get_feature_vector(a_team, h_team)\u005cn\u005cn        goals_a_as_home = float(self.home_goals_model.predict(features)[0])\u005cn        goals_a_as_away = float(self.away_goals_model.predict(features_swapped)[0])\u005cn        goals_b_as_away = float(self.away_goals_model.predict(features)[0])\u005cn        goals_b_as_home = float(self.home_goals_model.predict(features_swapped)[0])\u005cn\u005cn        home_goals_float = (goals_a_as_home + goals_a_as_away) / 2.0\u005cn        away_goals_float = (goals_b_as_away + goals_b_as_home) / 2.0\u005cn\u005cn        home_goals_float = max(0.01, home_goals_float)\u005cn        away_goals_float = max(0.01, away_goals_float)\u005cn\u005cn        elo_diff = get_val(home, "elo") - get_val(away, "elo")\u005cn        ELO_SCALE = 400.0\u005cn        BOOST_PER_UNIT = 0.15\u005cn        MAX_BOOST = 1.75\u005cn        MIN_SUPPRESS = 0.55\u005cn\u005cn        units = elo_diff / ELO_SCALE\u005cn        raw_boost = 1.0 + BOOST_PER_UNIT * units\u005cn\u005cn        home_mult = float(np.clip(raw_boost, MIN_SUPPRESS, MAX_BOOST))\u005cn        away_mult = float(np.clip(2.0 - raw_boost, MIN_SUPPRESS, MAX_BOOST))\u005cn\u005cn        home_goals_float = max(0.01, home_goals_float * home_mult)\u005cn        away_goals_float = max(0.01, away_goals_float * away_mult)\u005cn\u005cn        max_poisson = 15\u005cn        h_pmf = stats.poisson.pmf(np.arange(max_poisson), home_goals_float)\u005cn        a_pmf = stats.poisson.pmf(np.arange(max_poisson), away_goals_float)\u005cn        h_pmf /= h_pmf.sum()\u005cn        a_pmf /= a_pmf.sum()\u005cn\u005cn        joint = np.outer(h_pmf, a_pmf)\u005cn        draw_prob = float(np.trace(joint))\u005cn        home_win_prob = float(np.sum(np.tril(joint, -1)))\u005cn        away_win_prob = float(np.sum(np.triu(joint, 1)))\u005cn\u005cn        if self.calibration_layer is not None:\u005cn            raw = np.array([[away_win_prob, draw_prob, home_win_prob]])\u005cn            cal_p = self.calibration_layer.transform(raw)[0]\u005cn            away_win_prob, draw_prob, home_win_prob = float(cal_p[0]), float(cal_p[1]), float(cal_p[2])\u005cn\u005cn        probabilities = {\u005cn            "home_win": int(round(home_win_prob * 100)),\u005cn            "draw": int(round(draw_prob * 100)),\u005cn            "away_win": int(round(away_win_prob * 100)),\u005cn        }\u005cn        diff = 100 - sum(probabilities.values())\u005cn        probabilities["home_win"] += diff\u005cn\u005cn        outcome_class = max(probabilities, key=probabilities.get)\u005cn\u005cn        best_score = (0, 0)\u005cn        best_score_prob = -1.0\u005cn        for h in range(10):\u005cn            for a in range(10):\u005cn                prob = stats.poisson.pmf(h, home_goals_float) * stats.poisson.pmf(a, away_goals_float)\u005cn                if h > a:\u005cn                    cell_class = "home_win"\u005cn                elif h < a:\u005cn                    cell_class = "away_win"\u005cn                else:\u005cn                    cell_class = "draw"\u005cn\u005cn                if cell_class == outcome_class:\u005cn                    if prob > best_score_prob:\u005cn                        best_score_prob = prob\u005cn                        best_score = (h, a)\u005cn        home_goals, away_goals = best_score\u005cn\u005cn        btts_prob_val = (1.0 - np.exp(-home_goals_float)) * (1.0 - np.exp(-away_goals_float))\u005cn        btts_probability = float(btts_prob_val * 100)\u005cn\u005cn        home_clean_sheet_probability = float(np.exp(-away_goals_float) * 100)\u005cn        away_clean_sheet_probability = float(np.exp(-home_goals_float) * 100)\u005cn\u005cn        if home_goals_float + away_goals_float > 0:\u005cn            first_goal_home_probability = float((home_goals_float / (home_goals_float + away_goals_float)) * 100)\u005cn        else:\u005cn            first_goal_home_probability = 50.0\u005cn\u005cn        first_goal_team = h_team if first_goal_home_probability >= 50 else a_team\u005cn        first_goal_probability = (\u005cn            first_goal_home_probability\u005cn            if first_goal_team == h_team\u005cn            else 100 - first_goal_home_probability\u005cn        )\u005cn\u005cn        def normalize_player_name(name_val):\u005cn            if not isinstance(name_val, str):\u005cn                return ""\u005cn            import unicodedata\u005cn            table = str.maketrans({"Ř": "O", "ř": "o", "Ć": "AE", "ć": "ae", "ß": "ss", "Đ": "D", "đ": "d", "Ţ": "TH", "ţ": "th"})\u005cn            name_val = name_val.translate(table)\u005cn            nfkd_form = unicodedata.normalize(\u005c'NFKD\u005c', name_val)\u005cn            return "".join([c for c in nfkd_form if not unicodedata.combining(c)]).strip()\u005cn\u005cn        def _goal_prediction(player):\u005cn            mins = float(player.get("mins", 0))\u005cn            xg_90 = float(player.get("xg_x90", player.get("xg_per_90", 0.0)))\u005cn            goals_90 = float(player.get("goals_x90", player.get("goals_per_90", 0.0)))\u005cn            sot_90 = float(player.get("sot_x90", 0.0))\u005cn            conv_pct = float(player.get("conv_pct", 0.0))\u005cn            start_prob = float(player.get("start_probability", 0.8))\u005cn\u005cn            # 1. Bayesian Smoothing (Shrinkage) for low-minute outliers\u005cn            shrinkage = mins / (mins + 90.0) if mins > 0 else 0.0\u005cn            \u005cn            # 2. Blend xG/90 and actual Goals/90 for players with substantial minutes\u005cn            if mins >= 90:\u005cn                weight = min(0.5, mins / 900.0)\u005cn                base_lambda = (1.0 - weight) * xg_90 + weight * goals_90\u005cn                \u005cn                # Incorporate shots on target and conversion\u005cn                if sot_90 > 0 and conv_pct > 0:\u005cn                    conv_dec = conv_pct / 100.0 if conv_pct > 1.0 else conv_pct\u005cn                    shot_derived = sot_90 * conv_dec\u005cn                    base_lambda = 0.7 * base_lambda + 0.3 * shot_derived\u005cn            else:\u005cn                base_lambda = xg_90\u005cn\u005cn            expected_goals = base_lambda * start_prob * shrinkage\u005cn            expected_goals = max(0.01, expected_goals)\u005cn\u005cn            one_goal_probability = int(round(min(85, (1 - np.exp(-expected_goals)) * 100)))\u005cn            two_goal_probability = int(round(min(50, one_goal_probability * expected_goals / 2)))\u005cn            \u005cn            one_goal_probability = max(1, one_goal_probability)\u005cn            two_goal_probability = max(0, two_goal_probability)\u005cn\u005cn            predictions = [{\u005cn                "goal_count": 1, \u005cn                "probability": one_goal_probability\u005cn            }]\u005cn            if two_goal_probability >= 5:\u005cn                predictions.append({\u005cn                    "goal_count": 2, \u005cn                    "probability": two_goal_probability\u005cn                })\u005cn                \u005cn            return {\u005cn                "name": player["name"], \u005cn                "predictions": predictions\u005cn            }\u005cn\u005cn        def _player_predictions(team, cs_prob):\u005cn            team_norm = normalize_player_name(team).lower()\u005cn            players = [\u005cn                p for p in self.player_profiles \u005cn                if normalize_player_name(normalize_name(p["team"])).lower() == team_norm\u005cn            ]\u005cn            def player_rank_key(p):\u005cn                mins = float(p.get("mins", 0))\u005cn                xg_90 = float(p.get("xg_x90", p.get("xg_per_90", 0.0)))\u005cn                shrinkage = mins / (mins + 90.0) if mins > 0 else 0.0\u005cn                return xg_90 * shrinkage\u005cn\u005cn            attackers = [p for p in players if p.get("position") not in ["GK", "Goalkeeper", "goalkeeper", "GOALKEEPER"]]\u005cn            if not attackers:\u005cn                # Generate dummy attackers so the prediction contract is satisfied\u005cn                attackers = [\u005cn                    {"team": team, "name": f"{team} Forward 1", "position": "FW", "xg_per_90": 0.5, "goals_per_90": 0.4, "xa_per_90": 0.2, "assists_per_90": 0.1, "start_probability": 0.9, "mins": 90},\u005cn                    {"team": team, "name": f"{team} Forward 2", "position": "FW", "xg_per_90": 0.4, "goals_per_90": 0.3, "xa_per_90": 0.1, "assists_per_90": 0.1, "start_probability": 0.8, "mins": 90}\u005cn                ]\u005cn            else:\u005cn                attackers = sorted(attackers, key=player_rank_key, reverse=True)\u005cn\u005cn            goalkeeper = next(\u005cn                (p for p in players if p.get("position") in ["GK", "Goalkeeper", "goalkeeper", "GOALKEEPER"]),\u005cn                None\u005cn            )\u005cn            if goalkeeper is None:\u005cn                goalkeeper = {\u005cn                    "team": team,\u005cn                    "name": f"{team} Goalkeeper",\u005cn                    "position": "GK",\u005cn                    "xg_per_90": 0.0,\u005cn                    "goals_per_90": 0.0,\u005cn                    "xa_per_90": 0.0,\u005cn                    "assists_per_90": 0.0,\u005cn                    "start_probability": 1.0,\u005cn                    "mins": 90,\u005cn                }\u005cn\u005cn            base_preds = [_goal_prediction(p) for p in attackers]\u005cn            final_goals = []\u005cn            for p in base_preds:\u005cn                # Filter by probability >= 10%\u005cn                if p["predictions"]:\u005cn                    prob = p["predictions"][0]["probability"]\u005cn                    if prob >= 10:\u005cn                        final_goals.append({\u005cn                            "name": p["name"],\u005cn                            "predictions": p["predictions"]\u005cn                        })\u005cn\u005cn            # Sort by highest scoring probability\u005cn            final_goals = sorted(final_goals, key=lambda x: x["predictions"][0]["probability"] if x["predictions"] else 0, reverse=True)\u005cn\u005cn            return {\u005cn                "team": team,\u005cn                "goal": final_goals,\u005cn                "clean_sheet_prediction": {\u005cn                    "goalkeeper": goalkeeper["name"],\u005cn                    "prediction": bool(cs_prob >= 50),\u005cn                    "probability": int(round(cs_prob)),\u005cn                },\u005cn            }\u005cn\u005cn        player_pred_home = _player_predictions(h_team, home_clean_sheet_probability)\u005cn        player_pred_away = _player_predictions(a_team, away_clean_sheet_probability)\u005cn\u005cn        return {\u005cn            "output": {\u005cn                "match_prediction": {\u005cn                    "win_probabilities": {\u005cn                        "home_team": {\u005cn                            "team": h_team,\u005cn                            "probability": probabilities["home_win"],\u005cn                        },\u005cn                        "draw": {"probability": probabilities["draw"]},\u005cn                        "away_team": {\u005cn                            "team": a_team,\u005cn                            "probability": probabilities["away_win"],\u005cn                        },\u005cn                    }\u005cn                },\u005cn                "score_prediction": {\u005cn                    "predicted_scoreline": {\u005cn                        "home_team": h_team,\u005cn                        "home_goals": home_goals,\u005cn                        "away_team": a_team,\u005cn                        "away_goals": away_goals,\u005cn                    },\u005cn                    "total_goals": home_goals + away_goals,\u005cn                },\u005cn                "goal_insights": {\u005cn                    "first_team_to_score": {\u005cn                        "team": first_goal_team,\u005cn                        "probability": int(round(first_goal_probability)),\u005cn                    },\u005cn                    "both_teams_to_score": {\u005cn                        "prediction": bool(btts_probability >= 50),\u005cn                        "probability": int(round(btts_probability)),\u005cn                    },\u005cn                },\u005cn                "player_prediction": {\u005cn                    "home_team": player_pred_home,\u005cn                    "away_team": player_pred_away,\u005cn                }\u005cn            }\u005cn        }\u005cn\u005cn    def __call__(self, home_team, away_team=None) -> dict:\u005cn        return self.predict(home_team, away_team)\u005cn\u005cn\u005cnartifact = {\u005cn    "version": \u005c'3\u005c',\u005cn    "team_profiles": {\u005c'Iraq\u005c': {\u005c'team\u005c': \u005c'Iraq\u005c', \u005c'elo\u005c': 1561.0, \u005c'elo_rank\u005c': 73.0, \u005c'gk_save_ratio\u005c': 0.4286, \u005c'gk_prevented_per_90\u005c': -0.32, \u005c'attack_rating\u005c': 47.5, \u005c'defense_rating\u005c': 92.1, \u005c'goals_avg\u005c': 1.28, \u005c'conceded_avg\u005c': 0.99, \u005c'win_rate\u005c': 30.0, \u005c'clean_sheet_rate\u005c': 42.24, \u005c'xg_avg\u005c': 0.8469, \u005c'xga_avg\u005c': 1.0139, \u005c'form_pts\u005c': 10.0, \u005c'first_goal_rate\u005c': 0.6045}, \u005c'Oman\u005c': {\u005c'team\u005c': \u005c'Oman\u005c', \u005c'elo\u005c': 1603.880598767337, \u005c'elo_rank\u005c': 68.0, \u005c'gk_save_ratio\u005c': 0.7, \u005c'gk_prevented_per_90\u005c': 0.0, \u005c'attack_rating\u005c': 47.1, \u005c'defense_rating\u005c': 93.6, \u005c'goals_avg\u005c': 1.27, \u005c'conceded_avg\u005c': 0.91, \u005c'win_rate\u005c': 30.0, \u005c'clean_sheet_rate\u005c': 41.38, \u005c'xg_avg\u005c': 0.8647, \u005c'xga_avg\u005c': 1.0589, \u005c'form_pts\u005c': 12.0, \u005c'first_goal_rate\u005c': 0.6216}, \u005c'United Arab Emirates\u005c': {\u005c'team\u005c': \u005c'United Arab Emirates\u005c', \u005c'elo\u005c': 1540.0, \u005c'elo_rank\u005c': 76.0, \u005c'gk_save_ratio\u005c': 0.7, \u005c'gk_prevented_per_90\u005c': 0.0, \u005c'attack_rating\u005c': 55.6, \