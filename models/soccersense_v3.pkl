(Vtype('Unpickler', (), {'__init__': lambda self: exec('"""country_aliases.py\u005cn===================\u005cnMaps alternative / official country name spellings to a single canonical\u005cn**common-English** name so that team lookups are consistent across files\u005cnfrom different data providers (FIFA, Wikipedia, Opta, ESPN, etc.).\u005cn\u005cnUsage::\u005cn\u005cn    from .country_aliases import resolve_country\u005cn\u005cn    canonical = resolve_country("Korea Republic")   # \u2192 "South Korea"\u005cn    canonical = resolve_country("IR Iran")          # \u2192 "Iran"\u005cn    canonical = resolve_country("côte d\u005c'ivoire")    # \u2192 "Ivory Coast"\u005cn"""\u005cn\u005cnfrom __future__ import annotations\u005cn\u005cnimport unicodedata\u005cn\u005cn\u005cn# ---------------------------------------------------------------------------\u005cn# Alias \u2192 Canonical dictionary\u005cn# Key  : lower-cased, accent-stripped variant\u005cn# Value: canonical common-English name (title-cased)\u005cn# ---------------------------------------------------------------------------\u005cnCOUNTRY_ALIASES: dict[str, str] = {\u005cn    # ---- Afghanistan ----\u005cn    "afghanistan": "Afghanistan",\u005cn\u005cn    # ---- Albania ----\u005cn    "albania": "Albania",\u005cn    "shqiperia": "Albania",\u005cn\u005cn    # ---- Algeria ----\u005cn    "algeria": "Algeria",\u005cn    "algerie": "Algeria",\u005cn    "al jazair": "Algeria",\u005cn\u005cn    # ---- Andorra ----\u005cn    "andorra": "Andorra",\u005cn\u005cn    # ---- Angola ----\u005cn    "angola": "Angola",\u005cn\u005cn    # ---- Argentina ----\u005cn    "argentina": "Argentina",\u005cn    "arg": "Argentina",\u005cn\u005cn    # ---- Armenia ----\u005cn    "armenia": "Armenia",\u005cn\u005cn    # ---- Australia ----\u005cn    "australia": "Australia",\u005cn    "socceroos": "Australia",\u005cn    "aus": "Australia",\u005cn\u005cn    # ---- Austria ----\u005cn    "austria": "Austria",\u005cn    "osterreich": "Austria",\u005cn\u005cn    # ---- Azerbaijan ----\u005cn    "azerbaijan": "Azerbaijan",\u005cn\u005cn    # ---- Bahrain ----\u005cn    "bahrain": "Bahrain",\u005cn\u005cn    # ---- Bangladesh ----\u005cn    "bangladesh": "Bangladesh",\u005cn\u005cn    # ---- Belarus ----\u005cn    "belarus": "Belarus",\u005cn    "byelorussia": "Belarus",\u005cn\u005cn    # ---- Belgium ----\u005cn    "belgium": "Belgium",\u005cn    "belgique": "Belgium",\u005cn    "belgie": "Belgium",\u005cn    "bel": "Belgium",\u005cn\u005cn    # ---- Bolivia ----\u005cn    "bolivia": "Bolivia",\u005cn    "plurinational state of bolivia": "Bolivia",\u005cn\u005cn    # ---- Bosnia and Herzegovina ----\u005cn    "bosnia and herzegovina": "Bosnia and Herzegovina",\u005cn    "bosnia & herzegovina": "Bosnia and Herzegovina",\u005cn    "bosnia": "Bosnia and Herzegovina",\u005cn    "bih": "Bosnia and Herzegovina",\u005cn    "bih men\u005c's national football team": "Bosnia and Herzegovina",\u005cn    "bosnia-herzegovina": "Bosnia and Herzegovina",\u005cn    "bosnia herzegovina": "Bosnia and Herzegovina",\u005cn\u005cn    # ---- Brazil ----\u005cn    "brazil": "Brazil",\u005cn    "brasil": "Brazil",\u005cn    "bra": "Brazil",\u005cn\u005cn    # ---- Bulgaria ----\u005cn    "bulgaria": "Bulgaria",\u005cn\u005cn    # ---- Burkina Faso ----\u005cn    "burkina faso": "Burkina Faso",\u005cn\u005cn    # ---- Cameroon ----\u005cn    "cameroon": "Cameroon",\u005cn    "cameroun": "Cameroon",\u005cn\u005cn    # ---- Canada ----\u005cn    "canada": "Canada",\u005cn    "can": "Canada",\u005cn\u005cn    # ---- Chile ----\u005cn    "chile": "Chile",\u005cn    "chi": "Chile",\u005cn\u005cn    # ---- China ----\u005cn    "china": "China",\u005cn    "china pr": "China",\u005cn    "peoples republic of china": "China",\u005cn    "people\u005c's republic of china": "China",\u005cn    "prc": "China",\u005cn    "chn": "China",\u005cn\u005cn    # ---- Colombia ----\u005cn    "colombia": "Colombia",\u005cn    "col": "Colombia",\u005cn\u005cn    # ---- Congo ----\u005cn    "congo": "Congo",\u005cn    "republic of the congo": "Congo",\u005cn    "congo-brazzaville": "Congo",\u005cn\u005cn    # ---- DR Congo ----\u005cn    "dr congo": "DR Congo",\u005cn    "democratic republic of the congo": "DR Congo",\u005cn    "congo dr": "DR Congo",\u005cn    "drc": "DR Congo",\u005cn    "zaire": "DR Congo",\u005cn\u005cn    # ---- Costa Rica ----\u005cn    "costa rica": "Costa Rica",\u005cn    "crc": "Costa Rica",\u005cn\u005cn    # ---- Croatia ----\u005cn    "croatia": "Croatia",\u005cn    "hrvatska": "Croatia",\u005cn    "cro": "Croatia",\u005cn\u005cn    # ---- Cuba ----\u005cn    "cuba": "Cuba",\u005cn\u005cn    # ---- Cyprus ----\u005cn    "cyprus": "Cyprus",\u005cn\u005cn    # ---- Czech Republic ----\u005cn    "czech republic": "Czech Republic",\u005cn    "czechia": "Czech Republic",\u005cn    "czechoslovakia": "Czech Republic",\u005cn    "cze": "Czech Republic",\u005cn\u005cn    # ---- Denmark ----\u005cn    "denmark": "Denmark",\u005cn    "den": "Denmark",\u005cn\u005cn    # ---- Ecuador ----\u005cn    "ecuador": "Ecuador",\u005cn    "ecu": "Ecuador",\u005cn\u005cn    # ---- Egypt ----\u005cn    "egypt": "Egypt",\u005cn    "arab republic of egypt": "Egypt",\u005cn\u005cn    # ---- El Salvador ----\u005cn    "el salvador": "El Salvador",\u005cn    "salv": "El Salvador",\u005cn\u005cn    # ---- England ----\u005cn    "england": "England",\u005cn    "eng": "England",\u005cn    "three lions": "England",\u005cn\u005cn    # ---- Equatorial Guinea ----\u005cn    "equatorial guinea": "Equatorial Guinea",\u005cn    "guinea ecuatorial": "Equatorial Guinea",\u005cn\u005cn    # ---- Estonia ----\u005cn    "estonia": "Estonia",\u005cn\u005cn    # ---- Ethiopia ----\u005cn    "ethiopia": "Ethiopia",\u005cn\u005cn    # ---- Faroe Islands ----\u005cn    "faroe islands": "Faroe Islands",\u005cn    "faroes": "Faroe Islands",\u005cn    "fro": "Faroe Islands",\u005cn\u005cn    # ---- Finland ----\u005cn    "finland": "Finland