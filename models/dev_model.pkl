05cn\u005cn    # ---- Morocco ----\u005cn    "morocco": "Morocco",\u005cn    "maroc": "Morocco",\u005cn    "al maghrib": "Morocco",\u005cn    "mar": "Morocco",\u005cn\u005cn    # ---- Mozambique ----\u005cn    "mozambique": "Mozambique",\u005cn\u005cn    # ---- Netherlands ----\u005cn    "netherlands": "Netherlands",\u005cn    "holland": "Netherlands",\u005cn    "ned": "Netherlands",\u005cn    "dutch": "Netherlands",\u005cn\u005cn    # ---- New Zealand ----\u005cn    "new zealand": "New Zealand",\u005cn    "nzl": "New Zealand",\u005cn    "all whites": "New Zealand",\u005cn\u005cn    # ---- Nigeria ----\u005cn    "nigeria": "Nigeria",\u005cn    "nga": "Nigeria",\u005cn    "super eagles": "Nigeria",\u005cn\u005cn    # ---- Northern Ireland ----\u005cn    "northern ireland": "Northern Ireland",\u005cn    "nir": "Northern Ireland",\u005cn\u005cn    # ---- North Korea ----\u005cn    "north korea": "North Korea",\u005cn    "dpr korea": "North Korea",\u005cn    "democratic people\u005c's republic of korea": "North Korea",\u005cn    "korea dpr": "North Korea",\u005cn    "prk": "North Korea",\u005cn\u005cn    # ---- North Macedonia ----\u005cn    "north macedonia": "North Macedonia",\u005cn    "macedonia": "North Macedonia",\u005cn    "republic of north macedonia": "North Macedonia",\u005cn    "former yugoslav republic of macedonia": "North Macedonia",\u005cn    "fyrom": "North Macedonia",\u005cn    "mkd": "North Macedonia",\u005cn\u005cn    # ---- Norway ----\u005cn    "norway": "Norway",\u005cn    "norge": "Norway",\u005cn    "nor": "Norway",\u005cn\u005cn    # ---- Oman ----\u005cn    "oman": "Oman",\u005cn    "oman sultanate": "Oman",\u005cn\u005cn    # ---- Pakistan ----\u005cn    "pakistan": "Pakistan",\u005cn\u005cn    # ---- Palestine ----\u005cn    "palestine": "Palestine",\u005cn    "state of palestine": "Palestine",\u005cn\u005cn    # ---- Panama ----\u005cn    "panama": "Panama",\u005cn    "pan": "Panama",\u005cn\u005cn    # ---- Paraguay ----\u005cn    "paraguay