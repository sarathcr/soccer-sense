# Ignore everything by default
*

# Re-include only the files and folders we want to track
!/.gitignore
!/.vercelignore
!/README.md
!/requirements.txt
!/Dockerfile
!/vercel.json
!/pipeline_config.json

!/api/
!/api/index.py

!/data/
!/data/*.csv

!/models/
!/models/.gitkeep
!/models/*.pkl

!/scratch/
!/scratch/refactor_train.py

!/src/
!/src/football_ai/
!/src/football_ai/**

!/tests/
!/tests/**

# Keep local and generated files out of commits
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
.env
.env.*
.python-version
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.log
*.bak
